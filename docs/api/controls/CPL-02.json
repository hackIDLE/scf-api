{
  "control_id": "CPL-02",
  "title": "Security, Compliance & Resilience Controls Oversight",
  "family": "CPL",
  "description": "Mechanisms exist to provide a security, compliance and resilience controls oversight function that reports to the organization's executive leadership.",
  "scf_question": "Does the organization provide a security, compliance and resilience controls oversight function that reports to the organization's executive leadership?",
